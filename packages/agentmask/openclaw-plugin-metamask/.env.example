# OCAP URL for the vendor public facet (copy from the MetaMask extension's
# Kernel Management page or the offscreen console output).
OCAP_URL=

# Path to the ocap CLI. Auto-detected from the monorepo if omitted.
# OCAP_CLI_PATH=

# Daemon call timeout in ms (default: 60000).
# OCAP_TIMEOUT_MS=60000

# Set to "true" to clear all plugin state on each OpenClaw restart.
# Useful when iterating on the demo.
OCAP_RESET_STATE=true
